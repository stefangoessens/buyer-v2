# buyer-v2 extraction service environment variables
#
# Copy to services/extraction/.env for local service runs.
# Preview / staging / production values live in Railway.

# Deployment stage contract
APP_ENV=local

# Structured logging / release metadata
LOG_LEVEL=debug
SERVICE_VERSION=0.0.0

# Local bind port. Railway injects PORT in hosted environments.
PORT=8000

# Allowed web origins for local / lower-environment cross-service calls.
CORS_ORIGINS=http://localhost:3000
