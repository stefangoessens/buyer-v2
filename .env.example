# buyer-v2 environment variables
#
# Copy to .env.local and fill in real values for local dev.
# Production values live in Railway (railway variables --set KEY=VALUE).
#
# The autonomous loop reads this file as the canonical list of required vars.
# Adding a new env var: update this file + push to Railway in the same PR.
#
# Environment promotion model:
# - local      -> copied from this file into .env.local
# - preview    -> Railway per-PR environment
# - staging    -> shared Railway lower environment
# - production -> Railway production environment

# ─────────────────────────────────────────────
# Convex backend
# ─────────────────────────────────────────────
# Set automatically by `npx convex dev` — do not hand-edit
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Convex deploy key for CI / Railway production deploys
CONVEX_DEPLOY_KEY=

# ─────────────────────────────────────────────
# AI providers (loop touches these in P3/P4)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────
# Sentry — error tracking (web, convex, workers)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=kindservices
SENTRY_PROJECT=buyer-v2-web
NEXT_PUBLIC_SENTRY_DSN=

# PostHog — product analytics + funnels
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PERSONAL_API_KEY=

# ─────────────────────────────────────────────
# Auth (TBD — KIN-744 will pick provider)
# ─────────────────────────────────────────────
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ─────────────────────────────────────────────
# Property ingestion (P3 — fill in when those cards land)
# ─────────────────────────────────────────────
# BRIGHT_DATA_API_KEY=
# BROWSER_USE_API_KEY=
# RENTCAST_API_KEY=
# ATTOM_API_KEY=
# MAPBOX_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# Communication (P4)
# ─────────────────────────────────────────────
# RESEND_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ─────────────────────────────────────────────
# Railway (set by Railway runtime — do not commit)
# ─────────────────────────────────────────────
# RAILWAY_ENVIRONMENT=
# RAILWAY_PROJECT_ID=
# RAILWAY_SERVICE_NAME=
# PORT=

# ─────────────────────────────────────────────
# Linear (loop reads via MCP, but pin org for clarity)
# ─────────────────────────────────────────────
LINEAR_TEAM_KEY=KIN
LINEAR_PROJECT=buyer-v2

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
# Deployment stage contract. Set APP_ENV + NEXT_PUBLIC_APP_ENV together.
APP_ENV=local
NEXT_PUBLIC_APP_ENV=local

# Public origins. Keep NEXT_PUBLIC_SITE_URL and NEXT_PUBLIC_APP_URL aligned
# unless we intentionally split marketing and app hosts later.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Runtime metadata
LOG_LEVEL=debug
SERVICE_VERSION=0.0.0
NODE_ENV=development
