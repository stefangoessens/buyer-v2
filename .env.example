# buyer-v2 environment variables
#
# Copy to .env.local and fill in real values for local dev.
# Production values live in Railway (railway variables --set KEY=VALUE).
#
# The autonomous loop reads this file as the canonical list of required vars.
# Adding a new env var: update this file + push to Railway in the same PR.

# ─────────────────────────────────────────────
# Convex backend
# ─────────────────────────────────────────────
# Set automatically by `npx convex dev` — do not hand-edit
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Convex deploy key for CI / Railway production deploys
CONVEX_DEPLOY_KEY=

# ─────────────────────────────────────────────
# AI providers (loop touches these in P3/P4)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────
# Sentry — error tracking (web, convex, workers)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=kindservices
SENTRY_PROJECT=buyer-v2-web
NEXT_PUBLIC_SENTRY_DSN=

# PostHog — product analytics + funnels
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PERSONAL_API_KEY=

# ─────────────────────────────────────────────
# Auth (Convex Auth — self-hosted JWT, @convex-dev/auth)
# ─────────────────────────────────────────────
# Generate the JWT key pair once per environment with:
#   npx @convex-dev/auth --skip-git-check
# Then push the secrets to the Convex deployment:
#   npx convex env set JWT_PRIVATE_KEY "<generated>"
#   npx convex env set JWKS "<generated>"
#   npx convex env set SITE_URL "<origin>"
# JWT_PRIVATE_KEY + JWKS live in the Convex deployment env only —
# they are NEVER stored in this file.
SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Property ingestion (P3 — fill in when those cards land)
# ─────────────────────────────────────────────
# BRIGHT_DATA_UNLOCKER_TOKEN=
# BRIGHT_DATA_ZONE=buyer_v2_unlocker
# BRIGHT_DATA_MAX_CONCURRENT=4
# BRIGHT_DATA_MAX_REQUESTS_PER_MIN=60
# BRIGHT_DATA_MONTHLY_BUDGET_USD=500
# BRIGHT_DATA_FALLBACK_COST_PER_REQUEST_USD=0.0015
# RENTCAST_API_KEY=
# ATTOM_API_KEY=
# MAPBOX_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# Browser Use Cloud — used by python-workers/lib/browser_use_client.py
# (KIN-1076 ships the wrapper; provisioning + cutover are follow-up tasks)
# ─────────────────────────────────────────────
BROWSER_USE_API_KEY=
BROWSER_USE_BASE_URL=https://api.browser-use.com

# ─────────────────────────────────────────────
# Communication (P4)
# ─────────────────────────────────────────────
# RESEND_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ─────────────────────────────────────────────
# Railway (set by Railway runtime — do not commit)
# ─────────────────────────────────────────────
# RAILWAY_ENVIRONMENT=
# RAILWAY_PROJECT_ID=
# RAILWAY_SERVICE_NAME=
# PORT=

# ─────────────────────────────────────────────
# Linear (loop reads via MCP, but pin org for clarity)
# ─────────────────────────────────────────────
LINEAR_TEAM_KEY=KIN
LINEAR_PROJECT=buyer-v2

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
# Canonical web origin used by metadata, sitemap, and route shells
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
