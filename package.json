{
  "name": "@buyer-v2/web",
  "version": "0.0.0",
  "private": true,
  "description": "AI-native Florida buyer brokerage platform.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "bootstrap": "node scripts/bootstrap.mjs",
    "dev": "next dev --turbopack",
    "dev:web": "next dev --turbopack",
    "dev:backend": "pnpm --dir convex dev",
    "build": "next build",
    "build:web": "next build",
    "build:backend": "pnpm --dir convex typecheck",
    "build:ios": "cd ios/BuyerV2 && swift build",
    "build:workers": "pnpm workers:test",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc --noEmit",
    "typecheck:shared": "pnpm --dir packages/shared typecheck",
    "typecheck:backend": "pnpm --dir convex typecheck",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "ios:open": "open ios/BuyerV2/Package.swift",
    "ios:test": "cd ios/BuyerV2 && swift test",
    "workers:lib:test": "cd python-workers && python -m pytest",
    "workers:service:dev": "cd services/extraction && python -m uvicorn src.main:app --reload",
    "workers:service:test": "cd services/extraction && python -m pytest",
    "workers:test": "pnpm workers:lib:test && pnpm workers:service:test",
    "ci:web": "pnpm lint && pnpm typecheck:web && pnpm test && pnpm build:web",
    "ci:backend": "pnpm typecheck:backend",
    "ci:ios": "pnpm ios:test",
    "ci:workers": "pnpm workers:test",
    "lint": "next lint",
    "eval": "tsx scripts/ai-eval.ts",
    "eval:drift": "tsx scripts/ai-eval.ts drift"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.35.1",
    "next": "^15.3.0",
    "openai": "^6.34.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@sentry/nextjs": "^9.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.0",
    "posthog-js": "^1.200.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
